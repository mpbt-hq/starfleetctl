#!/bin/bash
#
# SPDX-License-Identifier: AGPL-3.0-or-later
# Copyright © 2026 Enrico Weigelt, metux IT consult
#
# Auto-installed by `starfleetctl bootstrap --fix` from
# github.com/mpbt-hq/starfleetctl (fragments/opencode-scripts/).
# Do NOT hand-edit this file — edit the canonical copy in the starfleetctl repo.
#
# Start an opencode control-agent session in the mpbt workspace root.
# Assigns a unique ship name (if none supplied) and runs in simple
# ship mode (listens to commands from the flagship).
#
# Usage:
#   ./run-opencode.ship [--name <id>] [-- <opencode args>]
#
#   --name <id>       override STARFLEET_SHIP_ID (default: next free ship name).
#
# The script registers an initial heartbeat on the agent‑bus board, then
# execs opencode (replacing this shell). Bus/board monitoring is handled
# by the opencode plugin in .opencode/plugins/.
#
# -------------------------------------------------------------------------

FLAGSHIP="Enterprise"
NAME=""

# Parse options
while [ "$#" -gt 0 ]; do
    case "$1" in
        --name)    shift; NAME="${1:-}" ;;
        -h|--help)
            sed -n '3,/^NAME=/p' "$0" | sed 's/^# \{0,1\}//; /^NAME=/d'
            exit 0 ;;
        --) shift; break ;;
        *) break ;;
    esac
    shift
done

# Determine STARFLEET_SHIP_ID (ship name)
if [ -n "${STARFLEET_SHIP_ID:-}" ] && [ -z "$NAME" ]; then
    NAME="$STARFLEET_SHIP_ID"
fi

if [ -z "$NAME" ]; then
    # Obtain next free ship name; fallback to random pid‑based name
    NAME="$("$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/starfleetctl" ship-names assign 2>/dev/null)" || true
    if [ -z "$NAME" ]; then
        NAME="ws-$$"
    fi
fi

export STARFLEET_SHIP_ID="$NAME"
export STARFLEET_ROLE="ship"
export STARFLEET_TARGET="${FLAGSHIP}"

# Register initial heartbeat (no cleanup possible; agent‑bus TTL / prune will reap it)
.starfleet-ai/bin/starfleetctl agent-bus status idle "opencode ship" >/dev/null 2>&1 || true

# (no background processes — plugins handle inbox/board monitoring)

# Override model via $STARFLEET_MODEL (e.g. nvidia/nvidia/nemotron-3-nano-30b-a3b)
MODEL=""
[ -n "${STARFLEET_MODEL:-}" ] && MODEL="--model ${STARFLEET_MODEL}"

WORKDIR=`pwd`
export OPENCODE_CONFIG_CONTENT="{\"username\":\"${STARFLEET_SHIP_ID}\"}"
#shellcheck disable=SC2086
exec opencode ${MODEL} --prompt "agent instructions in ${WORKDIR}/agents.d/index.md -- You are fleet ship ${STARFLEET_SHIP_ID:-unknown}, report to flagship ${FLAGSHIP}." "$@"
