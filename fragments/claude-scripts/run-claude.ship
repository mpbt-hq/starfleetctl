#!/bin/bash
#
# SPDX-License-Identifier: AGPL-3.0-or-later
# Copyright © 2026 Enrico Weigelt, metux IT consult
#
# Thin wrapper — all logic lives in `starfleetctl run`.
# Canonical source: mpbt-hq/starfleetctl (fragments/claude-scripts/).
# Do NOT hand-edit this file — edit the canonical copy in the starfleetctl repo.
#
# Usage:
#   ./run-claude.ship [--name <id>] [-- <claude args>]

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

# Parse --name to pass through to starfleetctl run
NAME=""
EXTRA=()
while [ "$#" -gt 0 ]; do
    case "$1" in
        --name) shift; NAME="${1:-}" ;;
        -h|--help)
            sed -n '3,/^NAME=/p' "$0" | sed 's/^# \{0,1\}//; /^NAME=/d'
            exit 0 ;;
        --) shift; EXTRA=("$@"); break ;;
        *) break ;;
    esac
    shift
done

ARGS=()
if [ -n "$NAME" ]; then
    ARGS+=(--name "$NAME")
fi
exec "$SCRIPT_DIR/starfleetctl" run --client claude "${ARGS[@]}" "${EXTRA[@]+"${EXTRA[@]}"}"
