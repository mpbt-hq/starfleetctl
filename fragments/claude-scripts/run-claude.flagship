#
# Thin wrapper — all logic lives in `starfleetctl run`.
# Canonical source: mpbt-hq/starfleetctl (fragments/claude-scripts/).
# Do NOT hand-edit this file — edit the canonical copy in the starfleetctl repo.
#
# Usage:
#   ./run-claude.flagship [-- <claude args>]

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
exec "$SCRIPT_DIR/starfleetctl" run --client claude --flagship "$@"
