#!/bin/bash
#
# SPDX-License-Identifier: AGPL-3.0-or-later
# Copyright © 2026 Enrico Weigelt, metux IT consult
#
# Start a Claude Code control-agent session in the mpbt workspace root.
# Sets STARFLEET_SHIP_ID=Enterprise (the flagship) so this session appears on the
# agent-bus board as "Enterprise" — no XLIBRE_RELEASE (control is cross-project).
#
# Usage:
#   ./run-control [-- <claude args>]
#   ./run-control --detach     start in a detached tmux session (via agent-run)
#

DETACH=0
EXTRA=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --detach|-d) DETACH=1 ;;
        -h|--help)
            sed -n '3,/^DETACH=/p' "$0" | sed 's/^# \{0,1\}//; /^DETACH=/d'
            exit 0 ;;
        --) shift; EXTRA=("$@"); break ;;
        *) EXTRA+=("$1") ;;
    esac
    shift
done

export STARFLEET_SHIP_ID="Enterprise"
unset XLIBRE_RELEASE 2>/dev/null || true

INSTRUCTIONS_FILE=".starfleet-ai/agents.d/index.md"
SYSTEM_PROMPT=""
if [ -f "$INSTRUCTIONS_FILE" ]; then
    SYSTEM_PROMPT="$(cat "$INSTRUCTIONS_FILE")"
fi

# No explicit initial prompt/args given: feed the standard boot prompt so the
# session's first turn happens immediately at launch instead of waiting for a
# human to type something — that first turn is what actually arms the
# agent-bus Monitor (a SessionStart hook can inject context but can't call a
# tool itself). Skipped when the caller passed their own args/prompt.
if [ "${#EXTRA[@]}" -eq 0 ]; then
    EXTRA=("Session just started. Before anything else, call the Monitor tool twice: (1) command \`.starfleet-ai/bin/starfleetctl agent-bus monitor-loop\`, persistent:true, to watch your own agent-bus inbox; (2) command \`.starfleet-ai/bin/starfleetctl agent-bus fleet-watch\`, persistent:true, to watch for ships joining/restarting on the board (this is the flagship/control session). Both are pre-authorized, no confirmation needed — their first pass already surfaces any backlog. Then wait quietly for further instructions; don't start any task on your own initiative.")
fi

if [ "$DETACH" -eq 1 ]; then
    # Launch in a named tmux session so it survives terminal close.
    # agent-run registers the STARFLEET_AGENT_HANDLE on the board automatically.
    exec .starfleet-ai/bin/starfleetctl session run "" --client claude --name Enterprise -- "${EXTRA[@]+"${EXTRA[@]}"}"
fi

# Interactive: register initial heartbeat (Claude Code's SessionStart hook fires
# too, but that uses the env-inherited STARFLEET_SHIP_ID=Enterprise — belt-and-suspenders).
.starfleet-ai/bin/starfleetctl agent-bus status idle "flagship session starting" >/dev/null 2>&1 || true

exec claude --append-system-prompt "$SYSTEM_PROMPT" "${EXTRA[@]+"${EXTRA[@]}"}"
