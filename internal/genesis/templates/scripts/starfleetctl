#!/usr/bin/env bash
#
# SPDX-License-Identifier: AGPL-3.0-or-later
# Copyright © 2026 Enrico Weigelt, metux IT consult
#
# starfleetctl — thin exec wrapper for the mpbt-hq/starfleetctl Go CLI, so
# it's invoked the same way every other fleet-coordination tool in this
# workspace is: `scripts/<name> [args...]`.
#
# Rebuilds the binary automatically whenever the source is newer (dev-loop
# convenience — this repo isn't installed anywhere, it's the live checkout
# under _WORK_/), then execs it with the resolved workspace root so it works
# from any cwd.
#
# Usage: scripts/starfleetctl <subcommand> [args…]
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(git -C "$HERE" rev-parse --show-toplevel)"
SRC="$ROOT/_WORK_/starfleetctl/sources/xlibre/starfleetctl"
BIN="$SRC/starfleetctl"

if [ ! -d "$SRC" ]; then
    echo "starfleetctl: not fetched yet — run ./run-fetch.starfleetctl first" >&2
    exit 1
fi

needs_build=0
[ -x "$BIN" ] || needs_build=1
if [ "$needs_build" -eq 0 ] && [ -n "$(find "$SRC" -name '*.go' -newer "$BIN" -print -quit)" ]; then
    needs_build=1
fi
if [ "$needs_build" -eq 1 ]; then
    ( cd "$SRC" && go build -o starfleetctl ./cmd/starfleetctl )
fi

exec env MPBT_WORKSPACE_ROOT="$ROOT" "$BIN" "$@"
