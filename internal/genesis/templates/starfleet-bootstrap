# starfleet-bootstrap — deploy starfleetctl into .starfleet-ai/ (Phase 2).
# Auto-generated by: starfleetctl genesis-init
# Phase A (once): starfleetctl genesis-init installs this script (committed).
# Phase B (fresh clone / update): this script pulls starfleetctl, builds it,
# places all artifacts under .starfleet-ai/, and runs bootstrap --fix.
#
# All artifacts under .starfleet-ai/ (gitignored). Only this script is
# committed. Re-run anytime for updates.
#
# Usage: ./starfleet-bootstrap
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

for t in git go; do
    command -v "$t" >/dev/null 2>&1 || { echo "missing: $t" >&2; exit 1; }
done

mkdir -p .starfleet-ai/src .starfleet-ai/bin

SRC=".starfleet-ai/src/starfleetctl"
BIN=".starfleet-ai/bin/starfleetctl"
REPO="git@github.com:mpbt-hq/starfleetctl.git"

if [[ -d "$SRC/.git" ]]; then
    echo "-- updating starfleetctl source --"
    git -C "$SRC" pull --ff-only origin master || true
else
    echo "-- cloning starfleetctl --"
    git clone "$REPO" "$SRC"
fi

echo "-- building starfleetctl --"
rm -f "$SRC/starfleetctl"
( cd "$SRC" && go build -o starfleetctl ./cmd/starfleetctl )
ln -sf ../src/starfleetctl/starfleetctl "$BIN"

echo "-- starfleetctl bootstrap --fix --"
"$BIN" bootstrap --fix

echo "starfleet-bootstrap: done — starfleetctl at .starfleet-ai/bin/starfleetctl"
