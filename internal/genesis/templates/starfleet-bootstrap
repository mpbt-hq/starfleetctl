# starfleet-bootstrap — deploy starfleetctl into .starfleet-ai/ (Phase 2).
# Auto-generated by: starfleetctl genesis-init
# Phase A (once): starfleetctl genesis-init installs this script (committed).
# Phase B (fresh clone / update): this script pulls starfleetctl (optionally
# pinned), builds it, places all artifacts under .starfleet-ai/, installs
# agent-config for claude & opencode.
#
# All artifacts under .starfleet-ai/ (gitignored). Only this script is committed.
# Re-run anytime for updates.
#
# Usage: ./starfleet-bootstrap [--pin <version>] [--clean]
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

SRC=".starfleet-ai/src/starfleetctl"
BIN=".starfleet-ai/bin/starfleetctl"
REPO="git@github.com:mpbt-hq/starfleetctl.git"
PIN=""
CLEAN=0

for arg in "$@"; do
    case "$arg" in
        --pin=*) PIN="${arg#*=}" ;;
        --pin) PIN="__NEXT_ARG__" ;;
        --clean) CLEAN=1 ;;
        -h|--help)
            echo "Usage: $0 [--pin <version>] [--clean]"
            echo "  --pin <ver>  checkout specific tag/commit instead of origin/master"
            echo "  --clean      remove .starfleet-ai/ before re-installing"
            exit 0
            ;;
        *) echo "starfleet-bootstrap: unknown option: $arg" >&2; exit 2 ;;
    esac
done

if [[ "$PIN" == "__NEXT_ARG__" ]]; then
    PIN="${1:-}"
    shift || { echo "starfleet-bootstrap: --pin requires a version" >&2; exit 2; }
fi

for t in git go; do
    command -v "$t" >/dev/null 2>&1 || { echo "missing: $t" >&2; exit 1; }
done

if [[ "$CLEAN" == 1 ]]; then
    echo "-- cleaning .starfleet-ai --"
    rm -rf .starfleet-ai
fi

mkdir -p .starfleet-ai/src .starfleet-ai/bin

if [[ -d "$SRC/.git" ]]; then
    echo "-- updating starfleetctl source --"
    git -C "$SRC" fetch -q origin
    if [[ -n "$PIN" ]]; then
        git -C "$SRC" checkout -q "$PIN"
    else
        git -C "$SRC" merge --ff-only origin/master || true
    fi
else
    echo "-- cloning starfleetctl --"
    git clone "$REPO" "$SRC"
    if [[ -n "$PIN" ]]; then
        git -C "$SRC" checkout -q "$PIN"
    fi
fi

# When starfleetctl is already built, delegate clone/build/link to it
if [[ -x "$BIN" ]] && [[ -z "$PIN" ]]; then
    "$BIN" self-install
else
    echo "-- building starfleetctl --"
    (
        cd "$SRC" && go build -o starfleetctl ./cmd/starfleetctl
    )
    ln -sf ../src/starfleetctl/starfleetctl "$BIN"
fi

SB="$ROOT/.starfleet-ai/bin/starfleetctl"
echo "-- starfleetctl bootstrap --fix --"
"$SB" bootstrap --fix

echo "-- starfleetctl agents reindex --"
MPBT_WORKSPACE_ROOT="$ROOT" "$SB" agents reindex

echo "starfleet-bootstrap: done — starfleetctl at .starfleet-ai/bin/starfleetctl"
