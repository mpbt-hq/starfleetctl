#
# Build of starfleetctl — runs its Makefile (builds the Go binary) via
# mpbt's `exec` builder. Separate from any other build in this workspace.
#

set -e

. cf/starfleetctl/config.sh

$MPBT -solution "$SOLUTION" -workdir "$WORKDIR" build
